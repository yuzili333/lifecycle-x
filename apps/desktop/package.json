{
  "name": "@lifecycle-x/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "存续期数据探针智能体桌面客户端",
  "main": "out/main/index.js",
  "type": "module",
  "astryx": {
    "theme": "@astryxdesign/theme-neutral"
  },
  "build": {
    "appId": "com.lifecycle-x.desktop",
    "productName": "Cycle Probe",
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico"
    }
  },
  "scripts": {
    "build": "electron-vite build",
    "dev": "ELECTRON_EXEC_PATH=./.electron/dist/electron node ./node_modules/electron-vite/bin/electron-vite.js dev",
    "native:rebuild": "node ./scripts/rebuild-native-deps.mjs",
    "preview": "ELECTRON_EXEC_PATH=./.electron/dist/electron node ./node_modules/electron-vite/bin/electron-vite.js preview",
    "test": "node ../../node_modules/vitest/vitest.mjs run src/main/streamingModelAdapter",
    "typecheck": "tsc --noEmit",
    "xds": "node node_modules/@astryxdesign/cli/bin/astryx.mjs"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.3",
    "@astryxdesign/theme-neutral": "^0.1.3",
    "@stylexjs/stylex": "^0.18.3",
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^12.11.1",
    "electron-vite": "^3.0.0",
    "lucide-react": "1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^33.2.1"
  }
}
