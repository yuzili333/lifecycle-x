{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cycle-probe.local/schemas/overall-risk-classification-report-data.schema.json",
  "title": "OverallRiskClassificationReportData",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reportTitle",
    "analysisScope",
    "totals",
    "fiveLevelDistribution",
    "riskIndicators",
    "dataQuality",
    "analysisText",
    "artifactRefs",
    "provenance"
  ],
  "properties": {
    "reportTitle": {
      "type": "string",
      "minLength": 1
    },
    "analysisScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filters"
      ],
      "properties": {
        "dataSourceName": {
          "type": "string"
        },
        "reportDate": {
          "type": "string"
        },
        "filters": {
          "type": "object"
        }
      }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractCount",
        "loanBalance",
        "amountUnit"
      ],
      "properties": {
        "contractCount": {
          "type": "number",
          "minimum": 0
        },
        "loanBalance": {
          "type": "number"
        },
        "contractAmount": {
          "type": "number"
        },
        "amountUnit": {
          "type": "string"
        }
      }
    },
    "fiveLevelDistribution": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fiveLevelItem"
      }
    },
    "twelveLevelDistribution": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/twelveLevelItem"
      }
    },
    "riskIndicators": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "normalCount",
        "attentionCount",
        "nonPerformingCount",
        "attentionPlusNonPerformingCount",
        "normalBalance",
        "attentionBalance",
        "nonPerformingBalance",
        "attentionPlusNonPerformingBalance",
        "nonPerformingCountRatio",
        "nonPerformingBalanceRatio",
        "attentionPlusNonPerformingCountRatio",
        "attentionPlusNonPerformingBalanceRatio"
      ],
      "properties": {
        "normalCount": {
          "type": "number"
        },
        "attentionCount": {
          "type": "number"
        },
        "nonPerformingCount": {
          "type": "number"
        },
        "attentionPlusNonPerformingCount": {
          "type": "number"
        },
        "normalBalance": {
          "type": "number"
        },
        "attentionBalance": {
          "type": "number"
        },
        "nonPerformingBalance": {
          "type": "number"
        },
        "attentionPlusNonPerformingBalance": {
          "type": "number"
        },
        "nonPerformingCountRatio": {
          "type": "number"
        },
        "nonPerformingBalanceRatio": {
          "type": "number"
        },
        "attentionPlusNonPerformingCountRatio": {
          "type": "number"
        },
        "attentionPlusNonPerformingBalanceRatio": {
          "type": "number"
        },
        "boundaryRiskCount": {
          "type": "number"
        },
        "boundaryRiskCountRatio": {
          "type": "number"
        },
        "boundaryRiskBalance": {
          "type": "number"
        },
        "boundaryRiskBalanceRatio": {
          "type": "number"
        }
      }
    },
    "dataQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duplicateContractCount",
        "missingClassificationCount",
        "missingBalanceCount",
        "unknownClassificationCount",
        "warnings"
      ],
      "properties": {
        "duplicateContractCount": {
          "type": "number",
          "minimum": 0
        },
        "missingClassificationCount": {
          "type": "number",
          "minimum": 0
        },
        "missingBalanceCount": {
          "type": "number",
          "minimum": 0
        },
        "unknownClassificationCount": {
          "type": "number",
          "minimum": 0
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "analysisText": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "countDimension",
        "amountDimension",
        "recommendations",
        "limitations"
      ],
      "properties": {
        "countDimension": {
          "type": "string"
        },
        "amountDimension": {
          "type": "string"
        },
        "normalInternalStructure": {
          "type": "string"
        },
        "boundaryRisk": {
          "type": "string"
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "artifactRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceDatasetArtifactId",
        "analysisArtifactId",
        "chartArtifactIds"
      ],
      "properties": {
        "sourceDatasetArtifactId": {
          "type": "string"
        },
        "analysisArtifactId": {
          "type": "string"
        },
        "chartArtifactIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sqlToolCallId",
        "pythonToolCallId",
        "chartToolCallIds",
        "generatedAt"
      ],
      "properties": {
        "sqlToolCallId": {
          "type": "string"
        },
        "pythonToolCallId": {
          "type": "string"
        },
        "chartToolCallIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "generatedAt": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "fiveLevelItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "contractCount",
        "contractCountRatio",
        "loanBalance",
        "loanBalanceRatio"
      ],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "正常",
            "关注",
            "次级",
            "可疑",
            "损失",
            "未识别"
          ]
        },
        "contractCount": {
          "type": "number"
        },
        "contractCountRatio": {
          "type": "number"
        },
        "loanBalance": {
          "type": "number"
        },
        "loanBalanceRatio": {
          "type": "number"
        },
        "remark": {
          "type": "string"
        }
      }
    },
    "twelveLevelItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classificationName",
        "contractCount",
        "contractCountRatio",
        "loanBalance",
        "loanBalanceRatio"
      ],
      "properties": {
        "classificationCode": {
          "type": "string"
        },
        "classificationName": {
          "type": "string"
        },
        "contractCount": {
          "type": "number"
        },
        "contractCountRatio": {
          "type": "number"
        },
        "loanBalance": {
          "type": "number"
        },
        "loanBalanceRatio": {
          "type": "number"
        }
      }
    }
  }
}
