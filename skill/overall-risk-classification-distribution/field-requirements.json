        "bf.loan_contract.contract_no",
        "credit.contract_id"
      ],
      "physicalName": "contract_serial",
      "displayNameZh": "合同流水号",
      "required": true,
      "expectedTypes": ["identifier", "string", "code"],
      "purpose": "合同唯一标识，用于去重计算笔数。优先使用主键/唯一字段 contract_serial；contract_no 仅作兼容候选。"
    },
    {
      "semantic": "five_level_classification",
      "businessFieldId": "bf.loan_contract.latest_risk",
      "compatibleBusinessFieldIds": [
        "bf.loan_contract.latest_five_level_risk",
        "credit.five_level_classification"
      ],
      "physicalName": "latest_risk",
      "displayNameZh": "最新风险分类",
      "required": true,
      "expectedTypes": ["enum", "category", "string"],
      "purpose": "整体风险分类统计字段，标准值为正常、关注、不良；兼容五级分类字段正常、关注、次级、可疑、损失。"
    },
    {
      "semantic": "twelve_level_classification",
      "businessFieldId": "bf.loan_contract.latest_risk_result",
